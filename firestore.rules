rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidUserProfile(data, userId) {
      return data.id == userId
        && data.name is string
        && data.name.size() > 0
        && data.name.size() <= 100
        && data.role in ['INSPECTOR', 'MANAGER', 'ADMIN'];
    }

    // Validation Blueprints
    function isValidInspection(data) {
      return data.id is string && data.id.size() <= 128
        && data.customerName is string && data.customerName.size() <= 200
        && data.orderNumber is string && data.orderNumber.size() <= 100
        && data.inspectorId is string && data.inspectorId == request.auth.uid
        && data.inspectorName is string && data.inspectorName.size() <= 100
        && data.status in ['DRAFT', 'COMPLETED', 'SYNCED']
        && data.rolls is list
        && data.rolls.size() <= 100 // Prevent memory exhaustion
        && data.totalPoints is number
        && data.pointsPer100Yds is number;
    }

    // Inspections Collection
    match /inspections/{inspectionId} {
      allow get: if isSignedIn() && (isAdmin() || existing().inspectorId == request.auth.uid);
      allow list: if isSignedIn() && (isAdmin() || resource.data.inspectorId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && isValidId(inspectionId)
        && isValidInspection(incoming())
        && incoming().id == inspectionId;

      allow update: if isSignedIn()
        && existing().inspectorId == request.auth.uid
        && isValidInspection(incoming())
        && incoming().id == existing().id
        && incoming().inspectorId == existing().inspectorId; // Identity lock

      allow delete: if false; // Deletion not allowed via mobile terminal for audit trail
    }

    // User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId)
        && incoming().id == userId
        && incoming().name is string
        && incoming().name.size() > 0
        && incoming().name.size() <= 100
        && incoming().role in ['INSPECTOR', 'MANAGER'];
      allow update: if isValidUserProfile(incoming(), userId)
        && (isAdmin() || (isOwner(userId) && incoming().role == existing().role));
    }
  }
}
